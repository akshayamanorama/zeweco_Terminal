# Copy this file to .env and fill in your values. Do not commit .env (it contains secrets).

# SQLite (default for local dev)
DATABASE_URL="file:./dev.db"

# Backend port (frontend proxies /api to this port in dev)
PORT=3004

# Production: allow frontend origin (e.g. https://terminal.zeweco.com)
# CORS_ORIGIN=https://terminal.zeweco.com

# SMTP for "Forgot password" emails (see SMTP-SETUP.txt for Gmail steps)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM="Zeweco Terminal <your-email@example.com>"
